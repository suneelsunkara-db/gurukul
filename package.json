{
  "name": "gurukul",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "description": "A self-evolving knowledge graph for LLM research with Socratic assessment.",
  "scripts": {
    "start": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "agent-server": "uv run start-server",
