  },
  "dependencies": {
    "@xyflow/react": "^12.11.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^10.0.3",
    "typescript": "~5.6.0",
    "vite": "^6.0.0"
  },
  "engines": {
    "node": ">=20.0"
  }
}
