# --- Databricks foundation model serving --------------------------------
# Workspace URL, no trailing slash. Example:
#   https://adb-1234567890123456.7.azuredatabricks.net
DATABRICKS_HOST=

# Auth is handled by the Databricks CLI's unified-auth subsystem. No
# secrets in this file. One-time setup on this machine:
#
#   1. brew install databricks  (or `pip install databricks-cli`)
#   2. databricks auth login --host $DATABRICKS_HOST
#      Pick "OAuth (machine-to-machine)" and follow prompts to bind
#      this profile to your service principal. The CLI stores
#      client_id/client_secret in your OS keyring, never on disk.
#   3. Verify: databricks auth token --host $DATABRICKS_HOST
#
# At runtime the journey CLI shells out to `databricks auth token` to
# get a short-lived OAuth access token. The CLI handles refresh,
# expiry, and keyring storage.
#
# Optional: if you maintain multiple profiles in ~/.databrickscfg,
# point at a specific one here.
DATABRICKS_CONFIG_PROFILE=

# Optional: override the `databricks` CLI binary path.
DATABRICKS_CLI=databricks

# Names of two model-serving endpoints. They can point at the same
# foundation model with different system prompts, or two genuinely
# different models (e.g. a strong "teacher" and a faster "student").
DATABRICKS_TEACHER_ENDPOINT=databricks-meta-llama-3-3-70b-instruct
DATABRICKS_STUDENT_ENDPOINT=databricks-meta-llama-3-1-8b-instruct

# --- Generation knobs ---------------------------------------------------
# Hard cap on tokens per single model call. Keeps cost predictable.
FM_MAX_TOKENS=2000

# Temperature for student (writer) and teacher (critic). Teacher should
# usually be cooler than student for tighter critique.
FM_TEMPERATURE_STUDENT=0.4
FM_TEMPERATURE_TEACHER=0.2

# --- Public site config (used by docusaurus.config.ts) -----------------
# Leave blank to default to your fork's GitHub Pages URL. Override if
# you publish under a custom domain.
SITE_URL=
SITE_BASE_URL=/gurukul/
GITHUB_ORG=
GITHUB_REPO=gurukul
