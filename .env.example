# --- Databricks workspace ------------------------------------------------
# Workspace URL, no trailing slash.
DATABRICKS_HOST=

# Auth: OAuth via Databricks CLI unified-auth. No secrets in this file.
#   1. brew install databricks
#   2. databricks auth login --host $DATABRICKS_HOST
#   3. Verify: databricks auth token --host $DATABRICKS_HOST
# In Databricks Apps, DATABRICKS_TOKEN is injected automatically.
DATABRICKS_CONFIG_PROFILE=

# --- Model serving endpoints (single source of truth) -------------------
TEACHER_MODEL=
STUDENT_MODEL=
EMBEDDING_MODEL=gurukul-specter2-embed

# --- Web search (Tavily) — for real-time model spec grounding -----------
# Get a free key at https://tavily.com
TAVILY_API_KEY=

# --- Scholarly retrieval (Semantic Scholar) -----------------------------
# Required for Semantic Scholar search in local tests/jobs.
S2_API_KEY=

# --- Corpus build knobs --------------------------------------------------
S2_CORPUS_QUERIES="Attention Is All You Need Vaswani;Training language models to follow instructions with human feedback Ouyang;Retrieval-Augmented Generation for Knowledge-Intensive NLP Tasks Lewis;ReAct Synergizing Reasoning and Acting in Language Models;Toolformer Language Models Can Teach Themselves to Use Tools;FlashAttention Fast and Memory-Efficient Exact Attention with IO-Awareness;LoRA Low-Rank Adaptation of Large Language Models Hu;Constitutional AI Harmlessness from AI Feedback;attention is all you need transformer;large language model architecture;instruction tuning large language models;reinforcement learning from human feedback;direct preference optimization language models;constitutional AI harmlessness;retrieval augmented generation;LLM agents reasoning acting;Toolformer language models tools;ReAct reasoning acting language models;mixture of experts large language models;Mixtral mixture of experts;low rank adaptation LoRA large language models;FlashAttention efficient attention;KV cache optimization large language models;speculative decoding language models;quantization large language models;long context language models;chain of thought reasoning language models;LLM evaluation benchmarks;LLM safety alignment jailbreak;multimodal large language models;Llama technical report;Qwen technical report;DeepSeek large language model technical report"
S2_LIMIT_PER_QUERY=40
EMBEDDING_BATCH_SIZE=16

# --- Generation knobs ---------------------------------------------------
AGENT_CONCURRENCY=4
# LOG_LEVEL=INFO

# --- Lakebase (Autoscaling Postgres) ------------------------------------
# Same env vars for BOTH local dev and Databricks Apps.
# Get these from the Lakebase Connect dialog in your workspace.
# For local dev, PGUSER is your Databricks email.
# For Databricks Apps, PGUSER is the app's DATABRICKS_CLIENT_ID.
PGHOST=
PGDATABASE=databricks_postgres
PGUSER=
ENDPOINT_NAME=projects/<project-id>/branches/<branch-id>/endpoints/<endpoint-id>
